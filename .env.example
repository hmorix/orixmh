# HMorix Platform Environment
# Copy to .env for local development. Do not commit real secrets.

# Application
APP_URL=https://your-domain.vercel.app
VERCEL_URL=your-domain.vercel.app
CLIENT_ORIGIN=https://your-domain.vercel.app
PORT=5000
DATABASE=supabase

# MongoDB Atlas - auth, users, profiles, sessions, OAuth links, blogs
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hmorix?retryWrites=true&w=majority

# MariaDB - optional alternative when DATABASE=mariadb
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_DATABASE=hmorix
MARIADB_USER=root
MARIADB_PASSWORD=

# Direct OAuth - Google and GitHub use backend OAuth, not Supabase Auth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Microsoft Auth - remains on Supabase Auth
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret

# Supabase Database, Storage, and Microsoft Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=Orixbucket
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Gmail SMTP - verification email, OTP, password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM_NAME=HMorix

# Sessions and JWT compatibility fallback
SESSION_SECRET=replace_with_32_plus_random_bytes
SESSION_TTL_MS=604800000
JWT_SECRET=replace_with_32_plus_random_bytes
JWT_REFRESH_SECRET=replace_with_32_plus_random_bytes
JWT_EXPIRES_IN=3600

# Upload and token policy
MAX_UPLOAD_SIZE=8388608
EMAIL_VERIFY_TTL_MS=86400000
OTP_TTL_MS=600000
OTP_RETRY_LIMIT=5
OTP_RESEND_LIMIT=5

# Client
VITE_APP_URL=https://your-domain.vercel.app
VITE_API_URL=/api
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_AI_ASSISTANT=true

# Admin bootstrap
ADMIN_EMAIL=admin@hmorix.com
