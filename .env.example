# ============================================
# HMorix Platform - Environment Variables
# ============================================
# For Vercel deployment: Add these in Vercel Dashboard > Settings > Environment Variables
# For local development: Copy this to .env and fill in your values
# ============================================

# ============================================
# DATABASE PROVIDER SWITCH
# Options: "supabase" or "mysql"
# Default: supabase (recommended for Vercel free tier)
# To switch to MySQL: change to DATABASE=mysql and fill MySQL vars below
# ============================================
DATABASE=supabase

# ============================================
# SUPABASE CONFIGURATION (Required when DATABASE=supabase)
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# ============================================

# Server-side (used by API serverless functions)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your_anon_key
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your_service_role_key

# Client-side (used by React frontend - MUST prefix with VITE_)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your_anon_key

# ============================================
# MYSQL/MARIADB (Required ONLY when DATABASE=mysql)
# Use this when you want to switch away from Supabase
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=hmorix
DB_POOL_SIZE=5

# ============================================
# AUTHENTICATION (Required ONLY for MySQL mode)
# Supabase mode uses Supabase Auth automatically
# ============================================
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=3600
REFRESH_TOKEN_SECRET=your_refresh_secret_here

# ============================================
# OPTIONAL: OAuth Providers
# Configure in Supabase Dashboard > Authentication > Providers
# Google: Enable Google provider, add Client ID & Secret from Google Cloud Console
# GitHub: Enable GitHub provider, add Client ID & Secret from GitHub Developer Settings
# ============================================

# ============================================
# OPTIONAL: Storage
# Supabase Storage is used by default (free tier: 1GB)
# ============================================
# STORAGE_PROVIDER=supabase
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET_NAME=hmorix-assets

# ============================================
# OPTIONAL: Email (for custom email templates)
# Supabase handles auth emails by default on free tier
# ============================================
# SENDGRID_API_KEY=your_sendgrid_key
# EMAIL_FROM=noreply@yourdomain.com
